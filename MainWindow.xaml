<Window x:Class="SchlagzeugVerwaltung.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" Title="Schlagzeug Unterricht Verwaltung" Height="700" Width="1100" MinHeight="600" MinWidth="900" Background="#1E1E1E" WindowStartupLocation="CenterScreen">
  <Grid>
    <TabControl Name="MainTabControl" Background="#1E1E1E" Padding="5">
      <TabItem Header="Schüler" FontSize="14">
        <Grid Margin="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Margin="0,0,10,0" Padding="10">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Text="Schülerliste" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
              <ListBox Name="SchuelerListBox" Grid.Row="1" Background="#2D2D2D" BorderThickness="0" SelectionChanged="SchuelerListBox_SelectionChanged">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#3C3C3C" CornerRadius="4" Padding="10" Margin="0,2">
                      <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" />
                        <TextBlock FontSize="12" Text="{Binding Stundensatz, StringFormat={}{0:0.00} € / Stunde}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ListBox>
              <Button Grid.Row="2" Content="Neuer Schüler" Padding="15,10" Margin="0,10,0,0" Click="NeuerSchueler_Click" />
            </Grid>
          </Border>
          <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15">
            <Grid Name="SchuelerDetailsPanel" Visibility="Collapsed">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Text="Schülerdetails" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
              <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Name:" VerticalAlignment="Center" />
                <TextBox Name="TxtName" Grid.Column="1" Padding="8" />
              </Grid>
              <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Telefon:" VerticalAlignment="Center" />
                <TextBox Name="TxtTelefon" Grid.Column="1" Padding="8" />
              </Grid>
              <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="E-Mail:" VerticalAlignment="Center" />
                <TextBox Name="TxtEmail" Grid.Column="1" Padding="8" />
              </Grid>
              <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Stundensatz:" VerticalAlignment="Center" />
                <TextBox Name="TxtStundensatz" Grid.Column="1" Padding="8" />
              </Grid>
              <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Fester Termin:" VerticalAlignment="Center" />
                <ComboBox Name="CmbFixerWochentag" Grid.Column="1">
                  <ComboBoxItem Content="--" Tag="0" />
                  <ComboBoxItem Content="Montag" Tag="1" />
                  <ComboBoxItem Content="Dienstag" Tag="2" />
                  <ComboBoxItem Content="Mittwoch" Tag="3" />
                  <ComboBoxItem Content="Donnerstag" Tag="4" />
                  <ComboBoxItem Content="Freitag" Tag="5" />
                  <ComboBoxItem Content="Samstag" Tag="6" />
                  <ComboBoxItem Content="Sonntag" Tag="7" />
                </ComboBox>
                <TextBlock Text="Uhrzeit:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,10,0" />
                <TextBox Name="TxtFixeUhrzeit" Grid.Column="3" Padding="8" ToolTip="z.B. 16:00" />
              </Grid>
              <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Notizen:" VerticalAlignment="Top" Margin="0,8,0,0" />
                <TextBox Name="TxtNotizen" Grid.Column="1" Padding="8" AcceptsReturn="True" TextWrapping="Wrap" />
              </Grid>
              <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Löschen" Background="#E81123" Padding="15,8" Margin="0,0,10,0" Click="SchuelerLoeschen_Click" />
                <Button Content="Speichern" Padding="15,8" Click="SchuelerSpeichern_Click" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Termine" FontSize="14">
        <Grid Margin="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Margin="0,0,10,0" Padding="15">
            <StackPanel>
              <TextBlock Text="Datum wählen" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <DatePicker Name="DatePickerTermin" SelectedDateChanged="DatePickerTermin_SelectedDateChanged" />
                <TextBox Name="TxtTerminZeit" Grid.Column="1" Margin="10,0,0,0" ToolTip="Uhrzeit z.B. 16:00" />
              </Grid>
              <Button Content="Termin hinzufügen" Padding="15,10" Margin="0,10,0,0" Click="TerminHinzufuegen_Click" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="130" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Termine" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                <ComboBox Name="CmbTerminMonat" Grid.Column="1" HorizontalAlignment="Left" Width="150" SelectionChanged="CmbTerminMonat_SelectionChanged" />
                <TextBlock Text="Name:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,10,0" />
                <ComboBox Name="CmbTerminSchueler" Grid.Column="3" Width="150" SelectionChanged="CmbTerminSchueler_SelectionChanged" />
              </Grid>
              <DataGrid Name="TermineDataGrid" Grid.Row="1" Background="#2D2D2D" BorderThickness="0" AutoGenerateColumns="False" CanUserAddRows="False" MouseDoubleClick="TermineDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Datum" Width="150" IsReadOnly="True" Binding="{Binding Datum, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                  <DataGridTextColumn Header="Schüler" Width="*" IsReadOnly="True" Binding="{Binding SchuelerName}" />
                  <DataGridTemplateColumn Header="bezahlt" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <CheckBox HorizontalAlignment="Center" IsChecked="{Binding Bezahlt, Mode=OneWay}" Click="TerminBezahlt_Click" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="X" Background="#E81123" Padding="5,2" Click="TerminLoeschen_Click" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Monatsübersicht" FontSize="14">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox Name="CmbMonat" Width="120" Margin="0,0,10,0" SelectionChanged="CmbMonat_SelectionChanged" />
            <ComboBox Name="CmbJahr" Width="100" SelectionChanged="CmbMonat_SelectionChanged" />
            <Button Content="Export CSV" Padding="15,8" Margin="20,0,0,0" Click="ExportCSV_Click" />
          </StackPanel>
          <DataGrid Name="MonatsuebersichtDataGrid" Grid.Row="1" Background="#2D2D2D" BorderThickness="0" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Schüler" Width="*" Binding="{Binding SchuelerName}" />
              <DataGridTextColumn Header="Stunden" Width="80" Binding="{Binding Stunden}" />
              <DataGridTextColumn Header="Zu zahlen" Width="100" Binding="{Binding Bezahlt, StringFormat={}{0:0.00} €}" />
              <DataGridTextColumn Header="Guthaben" Width="100" Binding="{Binding Guthaben, StringFormat={}{0:0.00} €}" />
              <DataGridTextColumn Header="Ausstehend" Width="100" Binding="{Binding Ausstehend, StringFormat={}{0:0.00} €}" />
            </DataGrid.Columns>
          </DataGrid>
          <Border Grid.Row="2" Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Gesamteinnahmen: " FontSize="14" />
              <TextBlock Name="TxtGesamteinnahmen" Foreground="#16C60C" FontSize="14" FontWeight="Bold" />
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Zahlungen" FontSize="14">
        <Grid Margin="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Margin="0,0,10,0" Padding="15">
            <StackPanel>
              <TextBlock Text="Zahlung erfassen" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
              <TextBlock Text="Schüler:" Margin="0,0,0,5" />
              <ComboBox Name="CmbSchuelerZahlung" Margin="0,0,0,10" />
              <TextBlock Text="Betrag:" Margin="0,0,0,5" />
              <TextBox Name="TxtBetrag" Padding="8" Margin="0,0,0,10" />
              <TextBlock Text="Datum:" Margin="0,0,0,5" />
              <DatePicker Name="DatePickerZahlung" Margin="0,0,0,15" />
              <Button Content="Zahlung speichern" Background="#16C60C" Padding="15,0" Height="35" Margin="0,235,0,10" Click="ZahlungSpeichern_Click" />
              <Button Content="Zahlungen zurücksetzen" Background="#E81123" Padding="15,0" Height="35" Margin="0,5,0,0" Click="ZahlungenZuruecksetzen_Click" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Text="Zahlungshistorie" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
              <DataGrid Name="ZahlungenDataGrid" Grid.Row="1" Background="#2D2D2D" BorderThickness="0" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Datum" Width="100" Binding="{Binding Datum, StringFormat={}{0:dd.MM.yyyy}}" />
                  <DataGridTextColumn Header="Schüler" Width="*" Binding="{Binding SchuelerName}" />
                  <DataGridTextColumn Header="Betrag" Width="100" Binding="{Binding Betrag, StringFormat={}{0:C}}" />
                  <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="X" Background="#E81123" Padding="5,2" Click="ZahlungLoeschen_Click" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Wochennotizen" FontSize="14">
        <Grid Margin="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Margin="0,0,10,0" Padding="15">
            <StackPanel>
              <TextBlock Text="Wochennotizen" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
              <TextBlock Text="Schüler:" Margin="0,0,0,5" />
              <ComboBox Name="CmbSchuelerWochennotiz" Margin="0,0,0,10" SelectionChanged="CmbSchuelerWochennotiz_SelectionChanged" />
              <TextBlock Text="Woche:" Margin="0,0,0,5" />
              <DatePicker Name="DatePickerWochennotiz" Margin="0,0,0,10" SelectedDateChanged="DatePickerWochennotiz_SelectedDateChanged" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Name="TxtAktuelleWoche" Text="Woche vom..." FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
              <DataGrid Name="WochennotizenDataGrid" Grid.Row="1" Background="#2D2D2D" BorderThickness="0" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Woche" Width="100" Binding="{Binding Woche, StringFormat={}{0:dd.MM.yyyy}}" />
                  <DataGridTextColumn Header="Notiz" Width="*" Binding="{Binding Notiz}" />
                  <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="X" Background="#E81123" Padding="5,2" Click="WochennotizLoeschen_Click" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="Neue Notiz:" Margin="0,0,0,5" />
                <TextBox Name="TxtNeueWochennotiz" Padding="8" AcceptsReturn="True" TextWrapping="Wrap" Height="80" Margin="0,0,0,10" />
                <Button Content="Notiz speichern" Padding="15,10" HorizontalAlignment="Right" Click="WochennotizSpeichern_Click" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
      <TabItem Header="Drum Notation" FontSize="14" Padding="10,5">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Text="Drum Notation" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
              <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Name:" Margin="0,0,0,5" />
                <TextBox Name="TxtDrumName" Padding="8" />
              </StackPanel>
              <ListBox Name="DrumNotationListBox" Grid.Row="2" Background="#383838" Foreground="#FFFFFFFF" BorderThickness="0" SelectionChanged="DrumNotationListBox_SelectionChanged" />
              <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <Button Content="Neu" Padding="15,8" Margin="0,0,0,5" Click="DrumNotationNeu_Click" />
                <Button Content="Speichern" Padding="15,8" Margin="0,0,0,5" Click="DrumNotationSpeichern_Click" />
                <Button Content="Speichern unter" Padding="15,8" Margin="0,0,0,5" Click="DrumNotationSpeichernUnter_Click" />
                <Button Content="Löschen" Background="#E81123" Padding="15,8" Click="DrumNotationLoeschen_Click" />
              </StackPanel>
            </Grid>
          </Border>
          <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="GrooveScribe" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="Neu laden" Margin="10,0,0,0" Padding="12,6" Click="GrooveScribeReload_Click" />
                <Button Content="Im Browser öffnen" Margin="10,0,0,0" Padding="12,6" Click="GrooveScribeOpenInBrowser_Click" />
              </StackPanel>
              <wv2:WebView2 Name="GrooveScribeWebView" Grid.Row="1" />
              <StackPanel Grid.Row="1" Visibility="Collapsed">
                <Canvas Name="DrumStaffCanvas" Width="10" Height="10" />
                <TextBlock Name="SelectedNoteValueText" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>


